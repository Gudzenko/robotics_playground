<?xml version="1.0"?>
<model>
  <name>indoor_building</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <description>
    Multi-room indoor building for cargo_bot simulation.
    7 rooms (A-G) + corridor with circular route A-B-D-corridor-E-C-A.
    Rooms F and G are dead-ends. All doors are 1.8m wide with wood frames.
    Room A: 8x8m entry hall. All other rooms: 5x5m.
  </description>
</model>
