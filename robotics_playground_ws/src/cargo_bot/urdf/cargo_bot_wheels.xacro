<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="cargo_bot_wheels" params="geometry">
    <joint name="${geometry.drive_wheels.left_joint}" type="continuous">
      <parent link="${geometry.frames.base_link}" />
      <child link="${geometry.drive_wheels.left_link}" />
      <origin xyz="${geometry.drive_wheels.x} ${geometry.drive_wheels.y_offset} ${geometry.drive_wheels.z}" rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>

    <link name="${geometry.drive_wheels.left_link}">
      <xacro:cylinder_inertial
        mass="${geometry.drive_wheels.mass}"
        radius="${geometry.drive_wheels.radius}"
        length="${geometry.drive_wheels.width}"
        origin_rpy="1.57079632679 0 0" />
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.radius}" length="${geometry.drive_wheels.width}" />
        </geometry>
        <material name="tire_black" />
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.radius}" length="${geometry.drive_wheels.width}" />
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 ${geometry.drive_wheels.hub_y_offset} 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.hub_radius}" length="${geometry.drive_wheels.hub_width}" />
        </geometry>
        <material name="safety_yellow" />
      </visual>
    </link>

    <joint name="${geometry.drive_wheels.right_joint}" type="continuous">
      <parent link="${geometry.frames.base_link}" />
      <child link="${geometry.drive_wheels.right_link}" />
      <origin xyz="${geometry.drive_wheels.x} ${-geometry.drive_wheels.y_offset} ${geometry.drive_wheels.z}" rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>

    <link name="${geometry.drive_wheels.right_link}">
      <xacro:cylinder_inertial
        mass="${geometry.drive_wheels.mass}"
        radius="${geometry.drive_wheels.radius}"
        length="${geometry.drive_wheels.width}"
        origin_rpy="1.57079632679 0 0" />
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.radius}" length="${geometry.drive_wheels.width}" />
        </geometry>
        <material name="tire_black" />
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.radius}" length="${geometry.drive_wheels.width}" />
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 ${-geometry.drive_wheels.hub_y_offset} 0" rpy="1.57079632679 0 0" />
        <geometry>
          <cylinder radius="${geometry.drive_wheels.hub_radius}" length="${geometry.drive_wheels.hub_width}" />
        </geometry>
        <material name="safety_yellow" />
      </visual>
    </link>

    <joint name="${geometry.rear_support.joint}" type="fixed">
      <parent link="${geometry.frames.base_link}" />
      <child link="${geometry.rear_support.link}" />
      <origin xyz="${geometry.rear_support.x} ${geometry.rear_support.y} ${geometry.rear_support.z}" rpy="0 0 0" />
    </joint>

    <link name="${geometry.rear_support.link}">
      <xacro:sphere_inertial
        mass="${geometry.rear_support.mass}"
        radius="${geometry.rear_support.radius}" />
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <sphere radius="${geometry.rear_support.radius}" />
        </geometry>
        <material name="tire_black" />
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <sphere radius="${geometry.rear_support.radius}" />
        </geometry>
      </collision>
    </link>

    <gazebo>
      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>${geometry.drive_wheels.left_joint}</left_joint>
        <right_joint>${geometry.drive_wheels.right_joint}</right_joint>
        <wheel_separation>${2 * geometry.drive_wheels.y_offset}</wheel_separation>
        <wheel_radius>${geometry.drive_wheels.radius}</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>${geometry.frames.base_footprint}</child_frame_id>
        <odom_publish_frequency>50</odom_publish_frequency>
      </plugin>
    </gazebo>
  </xacro:macro>
</robot>
